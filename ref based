mkdir -p results/S_S19/{bam,vcf,consensus,quast,annotation}
##move files
mv illumina.bam illumina.bam.bai results/S_S19/bam/
mv ont.bam ont.bam.bai results/S_S19/bam/
mv variants.vcf.gz* results/S_S19/vcf/
mv S_S19_consensus.fasta results/S_S19/consensus/
mv quast_prokka results/S_S19/quast/
mv annotation_S_S19 results/S_S19/annotation/
