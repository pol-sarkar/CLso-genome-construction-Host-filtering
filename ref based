STEP 1 — Make a working directory
mkdir -p reference_guided/S_S19
cd reference_guided/S_S19

STEP 2 — Link your files
ln -s ../../host_filtered_fastq/S_S19/S_S19_clean_R1.fastq.gz .
ln -s ../../host_filtered_fastq/S_S19/S_S19_clean_R2.fastq.gz .
ln -s ../../clso_nanopore_clean/S_S19_CLso_only.fastq.gz .
ln -s ../../reference/CLso_ref/ncbi_dataset/data/GCA_000183665.1/GCA_000183665.1_ASM18366v1_genomic.fna reference.fna

STEP 3 — Load tools
module load bwa minimap2 samtools bcftools

STEP 4 — Index the reference
bwa index reference.fna
samtools faidx reference.fna

STEP 5 — Map Illumina reads
bwa mem -t 16 reference.fna S_S19_clean_R1.fastq.gz S_S19_clean_R2.fastq.gz | samtools sort -@ 8 -o illumina.bam

samtools index illumina.bam
STEP 6 — Map ONT reads
minimap2 -t 16 -ax map-ont reference.fna S_S19_CLso_only.fastq.gz | samtools sort -@ 8 -o ont.bam

samtools index ont.bam

STEP 7 — Check coverage
samtools depth illumina.bam | awk '{sum+=$3} END {print "Illumina coverage =",sum/NR}'

samtools depth ont.bam | awk '{sum+=$3} END {print "ONT coverage =",sum/NR}'

###generate consensus genome
STEP 8 — Merge BAMs
samtools merge combined.bam illumina.bam ont.bam

samtools index combined.bam

STEP 9 — Call variants
bcftools mpileup -Ou -f reference.fna combined.bam | bcftools call -mv -Oz -o variants.vcf.gz
#index them
bcftools index variants.vcf.gz

STEP 10 — Build consensus genome
cat reference.fna | bcftools consensus variants.vcf.gz > S_S19_consensus.fasta

STEP 11 — Check final genome size
seqkit stats S_S19_consensus.fasta


STEP 12- validate quality:
quast S_S19_consensus.fasta -o quast_consensus
and
samtools depth illumina.bam | awk '{sum+=$3} END {print "Final Illumina coverage =",sum/NR}'

STEP 13- Annotate
prokka --outdir annotation_S_S19 --prefix S_S19 S_S19_consensus.fasta

quast.py annotation_S_S19/S_S19.fna -o quast_prokka

STEP 14
Circularization check (IMPORTANT for Liberibacter)
minimap2 S_S19_consensus.fasta S_S19_consensus.fasta

