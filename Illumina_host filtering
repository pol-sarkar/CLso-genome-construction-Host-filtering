zcat A_S1/A_S1_clean_R1.fastq.gz | wc -l
(this divide by 4, as fastq format uses 4lines per read= non-host paired end reads)
for i in */*_clean_R1.fastq.gz; do lines=$(zcat $i | wc -l); reads=$((lines/4)); echo -e "$(basename $i _clean_R1.fastq.gz)\t$reads"; done | sort -k2 -nr
