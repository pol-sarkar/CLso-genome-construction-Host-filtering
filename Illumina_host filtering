#!/bin/bash

#SBATCH --job-name=host_filter

#SBATCH --partition=epyc

#SBATCH --cpus-per-task=8

#SBATCH --mem=40G

#SBATCH --time=24:00:00

#SBATCH --array=1-19

#SBATCH --output=logs/host_filter_%A_%a.out

#SBATCH --error=logs/host_filter_%A_%a.err

module load bwa/0.7.19

module load samtools/1.22.1

PROJECT=/rhome/poulamis/shared/labprojects/WGS-Liberibacter-Pol
SAMPLE=$(sed -n "${SLURM_ARRAY_TASK_ID}p" $PROJECT/samples_host_filter.tsv)
R1=$PROJECT/NGS_trimmed_fastq/${SAMPLE}_R1_trimmed.fastq.gz
R2=$PROJECT/NGS_trimmed_fastq/${SAMPLE}_R2_trimmed.fastq.gz
REF=$PROJECT/reference/hosts/host_combined.fa
OUTDIR=$PROJECT/host_filtered_fastq/${SAMPLE}
mkdir -p $OUTDIR
echo "====================================="
echo "Sample: $SAMPLE"
echo "R1: $R1"
echo "R2: $R2"
echo "====================================="
bwa mem -t 8 $REF $R1 $R2 | \
samtools view -b -f 12 -F 256 | \
samtools sort -n -@ 8 -o $OUTDIR/${SAMPLE}.host_removed.bam
samtools fastq \
-1 $OUTDIR/${SAMPLE}_clean_R1.fastq.gz \
-2 $OUTDIR/${SAMPLE}_clean_R2.fastq.gz \
-0 /dev/null \
-s /dev/null \
-n \
$OUTDIR/${SAMPLE}.host_removed.bam
echo "Finished $SAMPLE"
date
