#!/bin/bash -l

#SBATCH --job-name=CLso_v3
#SBATCH --partition=epyc
#SBATCH --cpus-per-task=16
#SBATCH --mem=64G
#SBATCH --time=3-00:00:00
#SBATCH --array=0-16
#SBATCH --output=logs/%A_%a.out
#SBATCH --error=logs/%A_%a.err

set -euo pipefail

###############################################################################
# SAFETY FIX
###############################################################################

unset PS1 || true
source /etc/profile.d/modules.sh 2>/dev/null || true
module purge

###############################################################################
# MODULES
###############################################################################

module load bwa/0.7.19
module load minimap2/2.30
module load samtools/1.22.1
module load bcftools/1.22
module load seqkit/2.4.0

###############################################################################
# PATHS
###############################################################################

BASE="/bigdata/maucklab/shared/labprojects/WGS-Liberibacter-Pol"

OUT="$BASE/reference_guided/results"

ONT="$BASE/clso_nanopore_clean"

REF="/rhome/poulamis/shared/labprojects/WGS-Liberibacter-Pol/reference/CLso_ref/GCF_000183665.1_ASM18366v1_genomic.fna"

mkdir -p logs
mkdir -p "$OUT"

###############################################################################
# SAMPLE
###############################################################################

SAMPLE=$(sed -n "$((SLURM_ARRAY_TASK_ID+1))p" \
"$BASE/reference_guided/samples.txt")

echo "================================================="
echo "Processing sample: $SAMPLE"
echo "================================================="

###############################################################################
# OUTPUT DIRS
###############################################################################

WORKDIR="$OUT/$SAMPLE"

BAM_DIR="$WORKDIR/bam"
VCF_DIR="$WORKDIR/vcf"
CONS_DIR="$WORKDIR/consensus"
QC_DIR="$WORKDIR/quast"
ANN_DIR="$WORKDIR/annotation"

mkdir -p "$BAM_DIR"
mkdir -p "$VCF_DIR"
mkdir -p "$CONS_DIR"
mkdir -p "$QC_DIR"
mkdir -p "$ANN_DIR"

cd "$WORKDIR"

###############################################################################
# INPUT FILES
###############################################################################

R1="$BASE/host_filtered_fastq/$SAMPLE/${SAMPLE}_clean_R1.fastq.gz"
R2="$BASE/host_filtered_fastq/$SAMPLE/${SAMPLE}_clean_R2.fastq.gz"

ONT_READS="$ONT/${SAMPLE}_CLso_only.fastq.gz"

if [[ ! -f "$R1" ]]; then
    echo "Missing: $R1"
    exit 1
fi

if [[ ! -f "$R2" ]]; then
    echo "Missing: $R2"
    exit 1
fi

if [[ ! -f "$ONT_READS" ]]; then
    echo "Missing: $ONT_READS"
    exit 1
fi

###############################################################################
# REFERENCE
###############################################################################

ln -sf "$REF" reference.fna

###############################################################################
# ILLUMINA MAPPING
###############################################################################

echo "Running bwa mem..."

bwa mem -t 16 reference.fna "$R1" "$R2" \
| samtools sort -@ 8 -o "$BAM_DIR/illumina.bam"

samtools index "$BAM_DIR/illumina.bam"

###############################################################################
# ONT MAPPING
###############################################################################

echo "Running minimap2..."

minimap2 -t 16 -ax map-ont reference.fna "$ONT_READS" \
| samtools sort -@ 8 -o "$BAM_DIR/ont.bam"

samtools index "$BAM_DIR/ont.bam"

###############################################################################
# MERGE BAMS
###############################################################################

echo "Merging BAMs..."

samtools merge -f \
    "$BAM_DIR/combined.bam" \
    "$BAM_DIR/illumina.bam" \
    "$BAM_DIR/ont.bam"

samtools index "$BAM_DIR/combined.bam"

###############################################################################
# VARIANT CALLING
###############################################################################

echo "Calling variants..."

bcftools mpileup \
    -Ou \
    -f reference.fna \
    "$BAM_DIR/combined.bam" \
| bcftools call \
    -mv \
    -Oz \
    -o "$VCF_DIR/variants.vcf.gz"

bcftools index -f "$VCF_DIR/variants.vcf.gz"

###############################################################################
# CONSENSUS
###############################################################################

echo "Generating consensus..."

bcftools consensus \
    -f reference.fna \
    "$VCF_DIR/variants.vcf.gz" \
    > "$CONS_DIR/${SAMPLE}_consensus.fasta"

seqkit stats \
    "$CONS_DIR/${SAMPLE}_consensus.fasta" \
    > "$CONS_DIR/stats.txt"

###############################################################################
# QUAST (OPTIONAL)
###############################################################################

if command -v quast.py >/dev/null 2>&1; then

    echo "Running QUAST..."

    quast.py \
        "$CONS_DIR/${SAMPLE}_consensus.fasta" \
        -o "$QC_DIR" \
        --silent

else

    echo "QUAST not available - skipping"

fi

###############################################################################
# PROKKA (OPTIONAL)
###############################################################################

if module avail prokka >/dev/null 2>&1; then

    module load prokka/1.14.5

    prokka \
        "$CONS_DIR/${SAMPLE}_consensus.fasta" \
        --outdir "$ANN_DIR" \
        --prefix "$SAMPLE" \
        --genus Liberibacter \
        --kingdom Bacteria \
        --cpus 8 || true

fi

###############################################################################
# SUMMARY
###############################################################################

echo "DONE: $SAMPLE"

ls -lh "$CONS_DIR/${SAMPLE}_consensus.fasta"
======-===========================================================================
================================================================================
#RUN annotation from ref_guided folder
for f in */*_consensus.fasta; do [ -f "$f" ] || continue; sample=$(basename "$f" _consensus.fasta); echo "Annotating $sample"; prokka "$f" --outdir annotation_"$sample" --prefix "$sample"; done


##For quast

for f in */*_consensus.fasta; do
    sample=$(basename "$f" _consensus.fasta)
    echo "QUAST: $sample"
    quast.py "$f" -o quast_"$sample" --silent
done


## to check circularity
grep -i "circular" quast_*/report.txt

grep "# contigs" report.txt (you should get 1) OR for f in */quast_*/report.txt; do echo "==== $f ===="; grep "# contigs" "$f"; done
grep "Total length" report.txt (it should be around genome size)  OR for f in */quast_*/report.txt; do echo "==== $f ===="; grep "Total length" "$f"; done


## to export:
echo -e "Sample\tContigs\tGenome_Size" > assembly_summary.tsv && for f in */quast_*/report.tsv; do sample=$(echo $f | cut -d/ -f1); contigs=$(grep "^# contigs" "$f" | cut -f2); length=$(grep "^Total length" "$f" | cut -f2); echo -e "$sample\t$contigs\t$length"; done >> assembly_summary.tsv
cat assembly_summary.tsv
