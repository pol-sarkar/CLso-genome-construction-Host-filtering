module load bwa/0.7.19
module load samtools/1.22.1

cd /rhome/poulamis/shared/labprojects/WGS-Liberibacter-Pol/reference/CLso_ref

bwa index GCF_000183665.1_ASM18366v1_genomic.fna
samtools faidx GCF_000183665.1_ASM18366v1_genomic.fna

##Create CLso-enriched ONT reads for all samples.
nano clso_hpc_safe_v2.slurm

dos2unix clso_hpc_safe_v2.slurm


=====================================================================
=====================================================================
=======================================================================
## Run quast
module load quast
quast.py results/A_S1/consensus/A_S1_consensus.fasta -o quast_A_S1
quast.py results/R_S18/consensus/R_S18_consensus.fasta -o quast_R_S18
----------------------------------------------------------------------------------------
## Annotation
prokka results/A_S1/consensus/A_S1_consensus.fasta \
--outdir prokka_A_S1 \
--prefix A_S1 \
--genus Liberibacter \
--kingdom Bacteria

---------------------------------------------------------------------------------------
## to check circularity
grep -i "circular" quast_*/report.txt

grep "# contigs" report.txt (you should get 1) OR for f in */quast_*/report.txt; do echo "==== $f ===="; grep "# contigs" "$f"; done
grep "Total length" report.txt (it should be around genome size)  OR for f in */quast_*/report.txt; do echo "==== $f ===="; grep "Total length" "$f"; done


## to export:
echo -e "Sample\tContigs\tGenome_Size" > assembly_summary.tsv && for f in */quast_*/report.tsv; do sample=$(echo $f | cut -d/ -f1); contigs=$(grep "^# contigs" "$f" | cut -f2); length=$(grep "^Total length" "$f" | cut -f2); echo -e "$sample\t$contigs\t$length"; done >> assembly_summary.tsv
cat assembly_summary.tsv
