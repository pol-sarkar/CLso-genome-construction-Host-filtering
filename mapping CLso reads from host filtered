1. Go to project folder
cd ~/shared/labprojects/WGS-Liberibacter-Pol
2. Load required tools
module load Flye minimap2 samtools seqkit
3. Extract ONLY CLso-mapped ONT reads
minimap2 -t 16 -ax map-ont reference/CLso_ref/ncbi_dataset/data/GCA_000183665.1/GCA_000183665.1_ASM18366v1_genomic.fna Nanopore_host_filtered/S_S19_host_filtered.fastq.gz | samtools view -b -F 4 - > S_S19_CLso.bam

4. Convert mapped reads back to FASTQ
samtools fastq S_S19_CLso.bam | gzip > S_S19_CLso_only.fastq.gz

5. Keep only long high-quality reads
seqkit seq -m 5000 S_S19_CLso_only.fastq.gz | gzip > S_S19_CLso_5kb.fastq.gz

6. Check remaining data
seqkit stats S_S19_CLso_5kb.fastq.gz

7. Run Flye
flye --nano-raw S_S19_CLso_5kb.fastq.gz -g 1.3m -o flye_S19_final -t 4

8. seqkit stats flye_S19_final/assembly.fasta
