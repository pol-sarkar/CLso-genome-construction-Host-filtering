From : reference_guided

mkdir -p SNPs

REF="/rhome/poulamis/shared/labprojects/WGS-Liberibacter-Pol/reference/CLso_ref/GCF_000183665.1_ASM18366v1_genomic.fna"

for bam in results/*/bam/combined.bam; do sample=$(echo "$bam" | cut -d'/' -f2); echo "Processing $sample"; bcftools mpileup -f "$REF" "$bam" | bcftools call -mv --ploidy 1 -Oz -o SNPs/${sample}.vcf.gz; bcftools index -f SNPs/${sample}.vcf.gz; done
--------------------------------------------------------------------------------
#Filter
for vcf in SNPs/[A-S]_S*.vcf.gz; do sample=$(basename "$vcf" .vcf.gz); bcftools filter -e 'QUAL<20 || DP<10' -Oz -o SNPs/${sample}.filtered.vcf.gz "$vcf"; bcftools index -f SNPs/${sample}.filtered.vcf.gz; done
#check
ls SNPs/*.filtered.vcf.gz | wc -l

## Merge them
bcftools merge SNPs/*.filtered.vcf.gz -Oz -o merged.vcf.gz
bcftools index merged.vcf.gz

which vcf2phylip.py
